# ============================================================
# Node.js / TypeScript / Office Add-in — .gitignore
# ============================================================

# Dependencies
node_modules/

# Build outputs
dist/
build/
out/
lib/
.sourcemaps/

# TypeScript
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed

# Testing / Coverage
coverage/
nyc_output/
.jest-cache/

# Environment files
.env
.env.local
.env.*.local
.env.*

# OS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# IDEs and editors
.vscode/
.vscode-test/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Visual Studio
.vs/
UpgradeLog.htm

# AI assistant tools
.continue/

# Cache
.cache/
.cache-loader/

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfplan
terraform/crash.log

# Archives / packages
*.tgz
*.zip
*.tar.gz

# Generated version file
version.ts
